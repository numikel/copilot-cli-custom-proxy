# Rust / Cargo
/target
**/target
# Cargo.lock is committed for reproducible CI builds (this is a binary app).

# Tauri build output
/src-tauri/gen
/src-tauri/target

# Runtime config written by the settings window — holds the private endpoint URL
config.json

# Legacy/optional seed config — may contain a private endpoint address / model names
/config.toml

# UI preferences (tray-visible models, keyed by endpoint URL) — may reveal the
# private endpoint address
ui_state.json

# Misc
*.log
.DS_Store
.ai/**
.claude/**
