{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Copilot Proxy",
  "version": "0.1.0",
  "identifier": "com.example.copilot-proxy",
  "build": {
    "frontendDist": "./dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "settings",
        "title": "Copilot Proxy — Settings",
        "width": 460,
        "height": 380,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
