{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Settings window permissions: invoking app commands and driving the custom (frameless) title bar.",
  "windows": ["settings"],
  "permissions": [
    "core:default",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-start-dragging"
  ]
}
